# Sarvam API key — get from https://dashboard.sarvam.ai
SARVAM_API_KEY=your_key_here

# Postgres (matches compose.yaml defaults)
POSTGRES_URL=postgresql://voice:voice@localhost:5432/voice_agent

# Redis (matches compose.yaml defaults)
REDIS_URL=redis://localhost:6379/0

# Which seeded tenant to use for browser-mic testing in Stage 1.
# In Stage 3 we'll look this up from the dialed phone number instead.
DEMO_TENANT_ID=1

# Pipecat / WebRTC
WEBRTC_HOST=0.0.0.0
WEBRTC_PORT=7860

# Logging
LOG_LEVEL=INFO

# FastAPI tools service (Stage 2)
TOOLS_BASE_URL=http://localhost:8000

# Google Gemini LLM (priority over Ollama and Sarvam when both are set).
GOOGLE_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.5-flash

# Offline LLM fallback (Ollama). Used if GEMINI_MODEL is not set.
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1

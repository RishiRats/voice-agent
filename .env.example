# Sarvam API key — get from https://dashboard.sarvam.ai
SARVAM_API_KEY=your_key_here

# Postgres — generate a strong password with: openssl rand -hex 24
POSTGRES_PASSWORD=changeme_use_openssl_rand_hex_24
POSTGRES_URL=postgresql://voice:changeme_use_openssl_rand_hex_24@localhost:5432/voice_agent

# Redis — generate a separate strong password with: openssl rand -hex 24
REDIS_PASSWORD=changeme_use_openssl_rand_hex_24
REDIS_URL=redis://:changeme_use_openssl_rand_hex_24@localhost:6379/0

# Which seeded tenant to use for browser-mic testing in Stage 1.
# In Stage 3 we'll look this up from the dialed phone number instead.
DEMO_TENANT_ID=1

# Pipecat / WebRTC — use scripts/run-agent.sh to start the agent (it passes
# WEBRTC_HOST and WEBRTC_PORT as --host / --port to the Pipecat runner).
WEBRTC_HOST=127.0.0.1
WEBRTC_PORT=7860

# Logging
LOG_LEVEL=INFO

# FastAPI tools service (Stage 2) — bind host/port for the tools server.
# TOOLS_BASE_URL is derived automatically from TOOLS_HOST + TOOLS_PORT.
TOOLS_HOST=127.0.0.1
TOOLS_PORT=8000

# Google Gemini LLM (priority over Ollama and Sarvam when both are set).
GOOGLE_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.5-flash

# Offline LLM fallback (Ollama). Used if GEMINI_MODEL is not set.
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1
